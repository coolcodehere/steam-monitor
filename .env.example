# Copy to .env and fill in your values (never commit .env).
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_CHANNEL_ID=1234567890123456789
# User to @mention in that channel when the page changes (your Discord user ID)
DISCORD_NOTIFY_USER_ID=87620915126370304
# Role ID for @Steam Frame Interest — pinged on Steam Frame page changes
DISCORD_NOTIFY_ROLE_ID=1234567890123456789
